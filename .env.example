# Copy to .env and fill in. Never commit the real .env.

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Trading 212 ---
# The T212 API uses HTTP Basic auth — you need BOTH halves of the credential:
#   T212_API_KEY    = the API key   (the "username")
#   T212_API_SECRET = the API secret (the "password")
# Generate both in the T212 app (Settings -> API). Works on Invest + Stocks ISA.
# Use the demo (paper) credentials first; live only after the backtest gate.
T212_API_KEY=
T212_API_SECRET=
T212_ENV=demo            # demo | live

# --- Telegram (bot — for sending proposals/alerts) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=        # private group ID containing user + bot

# Bot username (no @) — used by the dashboard's Telegram Login Widget.
# Must be exposed to the browser, hence NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Optional — secret for signing dashboard session cookies.
# Defaults to TELEGRAM_BOT_TOKEN if unset (fine for single-user MVP).
SESSION_SECRET=

# Dashboard session duration in days (default 7).
# Increase for convenience, decrease for tighter security.
SESSION_TTL_DAYS=7

# Public URL of the deployed dashboard — used by the bot's /login command
# to construct magic links it DMs you (e.g. https://your-app.vercel.app).
# No trailing slash.
DASHBOARD_BASE_URL=

# --- Telegram (MTProto — for reading external signal channels) ---
# Get TELEGRAM_API_ID and TELEGRAM_API_HASH from https://my.telegram.org
# Get TELEGRAM_SESSION_STRING by running: python scripts/auth_telegram.py
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# --- Market data ---
FINNHUB_API_KEY=
FRED_API_KEY=
NEWSAPI_KEY=             # optional; leave blank to use free aggregators only
EDGAR_USER_AGENT="ai_agent/0.1 (your-email@example.com)"

# --- Storage ---
# Neon Postgres connection string (use the pooled endpoint for serverless)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# --- Dashboard: Connections page ---
# GitHub token (fine-grained, Actions: read-and-write on this repo) used by the
# dashboard's "Sync now" button to trigger the daily-trade-loop workflow.
# Set this in Vercel env vars; leave blank to disable the Sync button.
GITHUB_DISPATCH_TOKEN=

# --- Runtime ---
LOG_LEVEL=INFO
LLM_DAILY_COST_CAP_USD=3.0
LLM_DAILY_COST_ALERT_USD=2.0
RUN_MODE=dry_run         # dry_run | paper | live

# --- Tiered LLM routing (m18) ---
# Set LLM_TIERED=false to fall back to single-pass (backout plan).
LLM_TIERED=true
LLM_SCREENING_MODEL=claude-haiku-4-5-20251001
LLM_DECISION_MODEL=claude-opus-4-7
LLM_SHORTLIST_MAX=5      # max tickers forwarded from Haiku → Opus
