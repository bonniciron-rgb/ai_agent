# Copy to .env and fill in. Never commit the real .env.

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Trading 212 ---
# Use the demo (paper) key first. Live key only after backtest gate is passed.
T212_API_KEY=
T212_ENV=demo            # demo | live

# --- Telegram (bot — for sending proposals/alerts) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=        # private group ID containing user + bot

# --- Telegram (MTProto — for reading external signal channels) ---
# Get TELEGRAM_API_ID and TELEGRAM_API_HASH from https://my.telegram.org
# Get TELEGRAM_SESSION_STRING by running: python scripts/auth_telegram.py
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# --- Market data ---
FINNHUB_API_KEY=
FRED_API_KEY=
NEWSAPI_KEY=             # optional; leave blank to use free aggregators only
EDGAR_USER_AGENT="ai_agent/0.1 (your-email@example.com)"

# --- Storage ---
# Neon Postgres connection string (use the pooled endpoint for serverless)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# --- Runtime ---
LOG_LEVEL=INFO
LLM_DAILY_COST_CAP_USD=3.0
LLM_DAILY_COST_ALERT_USD=2.0
RUN_MODE=dry_run         # dry_run | paper | live
